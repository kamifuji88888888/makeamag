# Storage (local dev by default, S3 for production)
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3

# AWS S3 (required when STORAGE_PROVIDER=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket-name
# S3_SIGNED_URL_TTL=3600

# Auth — change in production
JWT_SECRET=change-me-to-a-long-random-string

# Restrict iframe embedding to specific domains (optional)
# FRAME_ANCESTORS='self' https://yourdomain.com
FRAME_ANCESTORS=*

# Canonical app host for custom domain routing (production)
# Readers visiting other hosts mapped to flipbooks see the flipbook at /
# CANONICAL_HOST=makeamag.com

# Shown in Publisher branding DNS instructions (optional, client-side)
# VITE_CANONICAL_HOST=makeamag.com

# Server
PORT=3001
NODE_ENV=development

# App URLs (used for Stripe redirects)
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# Admin dashboard (optional — protects /api/admin/metrics and /admin UI)
# ADMIN_SECRET=generate-a-long-random-string

# Grant a billing account a plan without Stripe (for founder/testing access).
# Find account ID in browser console: localStorage.getItem('makeamag_billing_account')
# BILLING_OVERRIDE_ACCOUNT_ID=your-billing-account-uuid
# BILLING_OVERRIDE_PLAN=pro

# Stripe (platform billing + Connect for reader paywalls)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Auto-create products/prices (prints env vars for Railway):
#   STRIPE_SECRET_KEY=sk_test_... npm run stripe:setup
#
# Or paste price IDs manually after creating them in Stripe Dashboard:
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_PUBLISHER_MONTHLY=price_...
# STRIPE_PRICE_PUBLISHER_ANNUAL=price_...
# Webhook endpoint: POST https://your-domain.com/api/billing/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
