# Storage (local dev by default, S3 for production)
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3

# AWS S3 (required when STORAGE_PROVIDER=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket-name
# S3_SIGNED_URL_TTL=3600

# Auth — change in production
JWT_SECRET=change-me-to-a-long-random-string

# Restrict iframe embedding to specific domains (optional)
# FRAME_ANCESTORS='self' https://yourdomain.com
FRAME_ANCESTORS=*

# Canonical app host for custom domain routing (production)
# Readers visiting other hosts mapped to flipbooks see the flipbook at /
# CANONICAL_HOST=makeamag.com

# Shown in Publisher branding DNS instructions (optional, client-side)
# VITE_CANONICAL_HOST=makeamag.com

# Server
PORT=3001
NODE_ENV=development

# App URLs (used for Stripe redirects)
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# Stripe Connect (optional — enables built-in publisher payments)
# STRIPE_SECRET_KEY=sk_test_...
# Create a Connect platform at https://dashboard.stripe.com/connect
