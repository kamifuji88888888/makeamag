# Production template for makeamag.com
# Copy values into your host's environment dashboard.

NODE_ENV=production
PORT=3001

# Public URLs (same origin when API + app share one host)
CLIENT_URL=https://makeamag.com
SERVER_URL=https://makeamag.com

# Auth — generate a long random string
JWT_SECRET=

# Custom domain routing
CANONICAL_HOST=makeamag.com

# Storage: use S3 for production (recommended)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_SIGNED_URL_TTL=3600

# Or local disk with a persistent volume mounted at /app/server/data
# STORAGE_PROVIDER=local

# Embed security (optional — restrict to customer sites)
FRAME_ANCESTORS=*

# Admin dashboard
# ADMIN_SECRET=

# Stripe (optional — enables /pricing checkout)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Auto-create products/prices:
#   STRIPE_SECRET_KEY=sk_live_... npm run stripe:setup
#
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_PUBLISHER_MONTHLY=price_...
# STRIPE_PRICE_PUBLISHER_ANNUAL=price_...
